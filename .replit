modules = ["python-3.11"]
[deployment]
deploymentTarget = "autoscale"
run = [
  "streamlit",
  "run",
  "app.py",
  "--server.port",
  "8501",
  "--server.address",
  "0.0.0.0",
  "--server.headless",
  "true",
]

[nix]
channel = "stable-25_05"
packages = [
  "cairo",
  "ffmpeg-full",
  "freetype",
  "ghostscript",
  "glibcLocales",
  "gobject-introspection",
  "gtk3",
  "pkg-config",
  "qhull",
  "tcl",
  "tk",
  "chromium",
]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 8501"
waitForPort = 8501

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 8501
externalPort = 80

[userenv]

[userenv.shared]
STREAMLIT_SERVER_ADDRESS = "0.0.0.0"
STREAMLIT_SERVER_HEADLESS = "true"
STREAMLIT_SERVER_PORT = "8501"
